	-- Power Factors
	
	mcm_pistol_factor = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_power_pistol") 	or	mcm_pistol_factor
	mcm_smg_factor = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_power_smg")         or   mcm_smg_factor
	mcm_shotgun_factor = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_power_shotgun") or   mcm_shotgun_factor
	mcm_rifle_factor = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_power_rifle")  or      mcm_rifle_factor 
	mcm_sniper_factor = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_power_sniper")   or   mcm_sniper_factor
	
	-- Speed Factors
	 mcm_pistol_factor_speed  = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_speed_pistol")  or mcm_pistol_factor_speed
	 mcm_smg_factor_speed     = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_speed_smg")    or mcm_smg_factor_speed
	 mcm_shotgun_factor_speed = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_speed_shotgun") or mcm_shotgun_factor_speed 
	 mcm_rifle_factor_speed   = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_speed_rifle") or  mcm_rifle_factor_speed
	 mcm_sniper_factor_speed  = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_speed_sniper")  or mcm_sniper_factor_speed
	 
	 -- Weight Modifiers
	mcm_weight_affect = ui_mcm.get("EFT_ADS/weight_affect")       
	mcm_weight_threshold = ui_mcm.get("EFT_ADS/weight_threshold") or mcm_weight_threshold 
    mcm_weight_factor = ui_mcm.get("EFT_ADS/weight_factor")       or mcm_weight_factor
	
	-- GL anim
	mcm_gl_anim = ui_mcm.get("EFT_ADS/gl_anim")

	-- Handling Factor
	mcm_handling_affect = ui_mcm.get("EFT_ADS/handling_affect")				
	mcm_handling_factor = ui_mcm.get("EFT_ADS/handling_factor")             or mcm_handling_factor
	mcm_max_handling_multiplier = ui_mcm.get("EFT_ADS/max_handling_factor") or mcm_max_handling_multiplier
	mcm_handling_exponent = ui_mcm.get("EFT_ADS/handling_exponent")         or mcm_handling_exponent
