	mcm_speed_out_multiplier = ui_mcm.get("EFT_ADS/Speed_Mulitplier_out") or mcm_speed_out_multiplier
	pistol_allowed = ui_mcm.get("EFT_ADS/Pistol_Allowed") 
	DEBUG = ui_mcm.get("EFT_ADS/Debug")
	mcm_power_in = ui_mcm.get("EFT_ADS/Speed_Mulitplier_in_power") or mcm_power_in
	mcm_power_out = ui_mcm.get("EFT_ADS/Speed_Mulitplier_out_power") or mcm_power_out
	play_anim = ui_mcm.get("EFT_ADS/Play_anim") 
	mcm_strength_affect = ui_mcm.get("EFT_ADS/Strength_factor") 
	mcm_arm_health_affect = ui_mcm.get("EFT_ADS/Arm_Health_factor") 
	mcm_arm_health_factor = ui_mcm.get("EFT_ADS/Arm_Health_factor_factor") or mcm_arm_health_factor
    mcm_strength_power_factor   = ui_mcm.get("EFT_ADS/Strength_power_factor_factor") or mcm_strength_power_factor
