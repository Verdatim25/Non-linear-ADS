	<string id="ui_mcm_EFT_ADS_Speed_Mulitplier_in">
        <text>Speed Multiplier ADS</text>
    </string>
	<string id="ui_mcm_EFT_ADS_Speed_Mulitplier_in_desc">
        <text>Speed mulitplier on the extra ADS in animation, lower means slower, higher means faster</text>
    </string>
	<string id="ui_mcm_EFT_ADS_min_speed">
        <text>Minimum Animation Speed</text>
    </string>
	<string id="ui_mcm_EFT_ADS_min_speed_desc">
        <text>Sets the minimum speed of the anim which the speed will be clamped to if its lower. Lower is worse, higher is better. Set to 0.9 to prevent overly sluggish anims.</text>
    </string>
	<string id="ui_mcm_EFT_ADS_max_speed">
        <text>Maximum Animation Speed</text>
    </string>
	<string id="ui_mcm_EFT_ADS_min_speed_desc">
        <text>Sets the maximum speed of the anim which the speed will be clamped to if its higher. Lower is worse, higher is better.</text>
    </string>
	
	<string id="ui_mcm_EFT_ADS_min_power">
        <text>Minimum Animation power</text>
    </string>
	<string id="ui_mcm_EFT_ADS_min_power_desc">
        <text>Sets the minimum power of the anim which the power will be clamped to if its lower. Higher is worse, lower is better.</text>
    </string>
	<string id="ui_mcm_EFT_ADS_max_power">
        <text>Maximum Animation power</text>
    </string>
	<string id="ui_mcm_EFT_ADS_max_power_desc">
        <text>Sets the minimum power of the anim which the power will be clamped to if its higher. Higher is worse, lower is better.</text>
    </string>
	
	<string id="ui_mcm_EFT_ADS_Speed_Mulitplier_in_power">
        <text>Power multiplier ADS</text>
    </string>
	<string id="ui_mcm_EFT_ADS_Speed_Mulitplier_in_power_desc">
        <text>Power multiplier on the ads in animation, higher means more noticeable, lower means less noticeable</text>
    </string>
	<string id="ui_mcm_EFT_ADS_Speed_Mulitplier_out">
        <text>Speed Multiplier un-ADS</text>
    </string>
	<string id="ui_mcm_EFT_ADS_Speed_Mulitplier_out_desc">
